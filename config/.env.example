# ── NetSentinel AI — Environment Variables ──────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับระบบของคุณ
# cp .env.example .env

# Database
DB_URL=mysql+mysqlconnector://root:YOUR_PASSWORD@localhost/network_ai_v2


# Device Credentials (ค่า default สำหรับ Telnet/SSH เข้า Router)
DEVICE_USERNAME=admin
DEVICE_PASSWORD=admin123
DEVICE_SECRET=admin123

# SNMP
SNMP_COMMUNITY=public

# SNMPv3 (ถ้าไม่ใส่ ระบบจะใช้ SNMPv2c อัตโนมัติ)
# SNMP_V3_USER=netsentinel
# SNMP_V3_AUTH=admin12345
# SNMP_V3_PRIV=admin12345
